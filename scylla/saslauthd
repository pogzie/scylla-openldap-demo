#
# Settings for saslauthd daemon (RPM/Rocky Linux format)
# This file is read by the saslauthd init script on RPM-based systems.
#

# Directory for saslauthd's socket, pid file, and other runtime files.
# This MUST be set for saslauthd to run properly.
SOCKETDIR=/var/run/saslauthd

# Authentication mechanism to use.
# Options: pam, ldap, kerberos5, rimap, shadow, sasldb, getpwent
# When using ldap, configuration is read from /etc/saslauthd.conf
MECH=ldap

# Additional flags for saslauthd.
# -V: Enable verbose logging
# -c: Enable credential caching
# Note: Do NOT use -d (daemon/foreground mode) as it prevents proper startup
FLAGS="-V -c"
